package rules;

import com.ftn.sbnz.fraud.model.models.Transaction;
import com.ftn.sbnz.fraud.model.models.CustomerProfile;
import com.ftn.sbnz.fraud.model.models.RiskScore;
import com.ftn.sbnz.fraud.model.models.TransactionType;
import com.ftn.sbnz.fraud.model.facts.SmallTransaction;
import com.ftn.sbnz.fraud.model.facts.MediumTransaction;
import com.ftn.sbnz.fraud.model.facts.LargeTransaction;
import com.ftn.sbnz.fraud.model.facts.ForeignTransaction;
import com.ftn.sbnz.fraud.model.facts.RiskyMerchantCategory;
import com.ftn.sbnz.fraud.model.facts.SuspiciousIP;
import com.ftn.sbnz.fraud.model.facts.NightTransaction;
import com.ftn.sbnz.fraud.model.facts.CompromisedCard;
import com.ftn.sbnz.fraud.model.facts.SpendingAnomaly;
import com.ftn.sbnz.fraud.model.facts.UnknownLocation;
import com.ftn.sbnz.fraud.model.facts.UnusualMerchant;
import com.ftn.sbnz.fraud.model.facts.UnusualTime;
import com.ftn.sbnz.fraud.model.facts.DailyLimitExceeded;
import com.ftn.sbnz.fraud.model.facts.HighFrequency;
import com.ftn.sbnz.fraud.model.facts.MultiCountry;
import com.ftn.sbnz.fraud.model.facts.AmountSpike;
import com.ftn.sbnz.fraud.model.facts.CardTestingPattern;
import com.ftn.sbnz.fraud.model.facts.ImpossibleTravel;
import com.ftn.sbnz.fraud.model.facts.VelocityAttack;
import com.ftn.sbnz.fraud.model.facts.DormantAwakening;
import com.ftn.sbnz.fraud.model.facts.FraudDecision;
import com.ftn.sbnz.fraud.model.facts.RiskFactor;
import com.ftn.sbnz.fraud.model.facts.RiskDependency;

// ============================================================
// BACKWARD CHAINING QUERY
// Rekurzivno prolazi stablo rizika (RiskDependency) i proverava
// da li je neki RiskFactor na listu stabla satisfied == true.
// ============================================================

query isRiskSatisfied(String factId, String customerId)
    // Bazni slucaj: list stabla - direktno pronadjen RiskFactor
    RiskFactor(id == factId, customerId == customerId, satisfied == true)
    or
    // Rekurzivni slucaj: cvor ima dete koje je zadovoljeno
    (
        RiskDependency(parentId == factId, $childId : childId)
        and isRiskSatisfied($childId, customerId;)
    )
end

// ============================================================
// NIVO 1 - Klasifikacija transakcije
// ============================================================

rule "R1.1 - Small Transaction"
    salience 100
when
    $t : Transaction(amount < 50)
    not SmallTransaction(transactionId == $t.id)
then
    insert(new SmallTransaction($t.id));
end

rule "R1.2 - Medium Transaction"
    salience 100
when
    $t : Transaction(amount >= 50, amount < 500)
    not MediumTransaction(transactionId == $t.id)
then
    insert(new MediumTransaction($t.id));
end

rule "R1.3 - Large Transaction"
    salience 100
when
    $t : Transaction(amount >= 500)
    not LargeTransaction(transactionId == $t.id)
then
    insert(new LargeTransaction($t.id));
end

rule "R1.4 - Foreign Transaction"
    salience 100
when
    $t : Transaction($country : country)
    $p : CustomerProfile(customerId == $t.customerId, homeCountry != $country)
    not ForeignTransaction(transactionId == $t.id)
then
    insert(new ForeignTransaction($t.id));
end

rule "R1.5 - Risky Merchant Category"
    salience 100
when
    $t : Transaction(mccCode in ("electronics", "gambling", "crypto", "jewelry"))
    not RiskyMerchantCategory(transactionId == $t.id)
then
    insert(new RiskyMerchantCategory($t.id));
end

rule "R1.6 - Suspicious IP"
    salience 100
when
    // TODO: inject blacklisted IP countries list
    $t : Transaction(type == com.ftn.sbnz.fraud.model.models.TransactionType.ONLINE,
                     ipAddress != null)
    not SuspiciousIP(transactionId == $t.id)
then
    // insert(new SuspiciousIP($t.id));
end

rule "R1.7 - Night Transaction"
    salience 100
when
    $t : Transaction(timestamp.getHour() < 6 || timestamp.getHour() > 23)
    not NightTransaction(transactionId == $t.id)
then
    insert(new NightTransaction($t.id));
end

rule "R1.8 - Compromised Card"
    salience 100
when
    $t : Transaction($cardId : cardId)
    CompromisedCard(cardId == $cardId)
then
    // fact already in session - handled in R2.5
end

// ============================================================
// NIVO 2 - Odstupanja od profila
// ============================================================

rule "R2.1 - Spending Anomaly"
    salience 80
when
    $t : Transaction($id : id, $amount : amount, $cid : customerId)
    LargeTransaction(transactionId == $id)
    $p : CustomerProfile(customerId == $cid,
                         $avg : avgMonthlySpending,
                         eval($amount > 3 * ($avg / 30)))
    $rs : RiskScore(transactionId == $id)
    not SpendingAnomaly(transactionId == $id)
then
    insert(new SpendingAnomaly($id));
    $rs.addScore(15, "R2.1 SpendingAnomaly");
    update($rs);
end

rule "R2.2 - Unknown Location"
    salience 80
when
    $t : Transaction($id : id, $country : country, $cid : customerId)
    ForeignTransaction(transactionId == $id)
    $p : CustomerProfile(customerId == $cid,
                         eval(!$p.getKnownCountries().contains($country)))
    $rs : RiskScore(transactionId == $id)
    not UnknownLocation(transactionId == $id)
then
    insert(new UnknownLocation($id));
    $rs.addScore(10, "R2.2 UnknownLocation");
    update($rs);
end

rule "R2.3 - Unusual Merchant"
    salience 80
when
    $t : Transaction($id : id, $mcc : mccCode, $cid : customerId)
    RiskyMerchantCategory(transactionId == $id)
    $p : CustomerProfile(customerId == $cid,
                         eval(!$p.getUsualMccCodes().contains($mcc)))
    $rs : RiskScore(transactionId == $id)
    not UnusualMerchant(transactionId == $id)
then
    insert(new UnusualMerchant($id));
    $rs.addScore(10, "R2.3 UnusualMerchant");
    update($rs);
end

rule "R2.4 - Unusual Time"
    salience 80
when
    $t : Transaction($id : id, $cid : customerId)
    NightTransaction(transactionId == $id)
    $p : CustomerProfile(customerId == $cid, nightActivityFlag == false)
    $rs : RiskScore(transactionId == $id)
    not UnusualTime(transactionId == $id)
then
    insert(new UnusualTime($id));
    $rs.addScore(5, "R2.4 UnusualTime");
    update($rs);
end

rule "R2.5 - Compromised Card Score"
    salience 80
when
    $t : Transaction($id : id, $cardId : cardId)
    CompromisedCard(cardId == $cardId)
    $rs : RiskScore(transactionId == $id)
then
    $rs.addScore(40, "R2.5 CompromisedCard");
    update($rs);
end

rule "R2.6 - Suspicious IP and Foreign"
    salience 80
when
    $t : Transaction($id : id)
    SuspiciousIP(transactionId == $id)
    ForeignTransaction(transactionId == $id)
    $rs : RiskScore(transactionId == $id)
then
    $rs.addScore(15, "R2.6 SuspiciousIP+Foreign");
    update($rs);
end

// ============================================================
// NIVO 3 - Agregati (accumulate) i CEP obrasci
// TODO: implementirati accumulate i CEP pravila
// ============================================================

// R3.1 - DailyLimitExceeded (accumulate - SUM over 24h)
// R3.2 - HighFrequency (accumulate - COUNT over 1h)
// R3.3 - MultiCountry (accumulate - COUNT DISTINCT countries over 6h)
// R3.4 - AmountSpike (accumulate - AVG over 30d)
// R3.5 - CardTestingPattern (CEP - 3+ transactions < 5e in 10 min)
// R3.6 - ImpossibleTravel (CEP - 2 countries, time < physical travel)
// R3.7 - VelocityAttack (CEP - 5+ transactions in 5 min)
// R3.8 - DormantAwakening (CEP - no transactions 6+ months, then LargeTransaction)

// ============================================================
// NIVO 4 - Bonusi i finalna odluka
// ============================================================

rule "R4.1 - Card Testing + Large/Medium bonus"
    salience 40
when
    $t : Transaction($id : id)
    CardTestingPattern(cardId == $t.cardId)
    (LargeTransaction(transactionId == $id) or MediumTransaction(transactionId == $id))
    $rs : RiskScore(transactionId == $id)
then
    $rs.addScore(30, "R4.1 CardTesting+LargeMedium bonus");
    update($rs);
end

rule "R4.2 - Impossible Travel + Foreign bonus"
    salience 40
when
    $t : Transaction($id : id)
    ImpossibleTravel(cardId == $t.cardId)
    ForeignTransaction(transactionId == $id)
    $rs : RiskScore(transactionId == $id)
then
    $rs.addScore(20, "R4.2 ImpossibleTravel+Foreign bonus");
    update($rs);
end

rule "R4.3 - Spending + Unknown + Risky merchant bonus"
    salience 40
when
    $t : Transaction($id : id)
    SpendingAnomaly(transactionId == $id)
    UnknownLocation(transactionId == $id)
    RiskyMerchantCategory(transactionId == $id)
    $rs : RiskScore(transactionId == $id)
then
    $rs.addScore(15, "R4.3 SpendingAnomaly+UnknownLocation+RiskyMerchant bonus");
    update($rs);
end

rule "R4.7 - Compromised Card immediate BLOCK"
    salience 200
when
    $t : Transaction($id : id, $cardId : cardId, $cid : customerId)
    CompromisedCard(cardId == $cardId)
    $rs : RiskScore(transactionId == $id)
    not FraudDecision(transactionId == $id)
then
    insert(new FraudDecision($id, $cid,
        FraudDecision.Decision.BLOCK,
        $rs.getScore(),
        $rs.getFiredRules()));
    System.out.println("BLOCK - Compromised card: " + $cardId);
end

rule "R4.4 - APPROVE"
    salience 10
when
    $t : Transaction($id : id, $cid : customerId)
    $rs : RiskScore(transactionId == $id, score < 30)
    not FraudDecision(transactionId == $id)
then
    insert(new FraudDecision($id, $cid,
        FraudDecision.Decision.APPROVE,
        $rs.getScore(),
        $rs.getFiredRules()));
    System.out.println("APPROVE - score: " + $rs.getScore());
end

rule "R4.5 - REVIEW"
    salience 10
when
    $t : Transaction($id : id, $cid : customerId)
    $rs : RiskScore(transactionId == $id, score >= 30, score < 80)
    not FraudDecision(transactionId == $id)
then
    insert(new FraudDecision($id, $cid,
        FraudDecision.Decision.REVIEW,
        $rs.getScore(),
        $rs.getFiredRules()));
    System.out.println("REVIEW - score: " + $rs.getScore());
end

rule "R4.6 - BLOCK"
    salience 10
when
    $t : Transaction($id : id, $cid : customerId)
    $rs : RiskScore(transactionId == $id, score >= 80)
    not FraudDecision(transactionId == $id)
then
    insert(new FraudDecision($id, $cid,
        FraudDecision.Decision.BLOCK,
        $rs.getScore(),
        $rs.getFiredRules()));
    System.out.println("BLOCK - score: " + $rs.getScore());
end
