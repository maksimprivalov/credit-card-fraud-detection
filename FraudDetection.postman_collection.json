        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "{{baseUrl}}/fraud-detection/analyze", "host": ["{{baseUrl}}"], "path": ["fraud-detection", "analyze"]},
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transaction\": {\n    \"id\": \"tx-daily-5\",\n    \"cardId\": \"card-maja\",\n    \"customerId\": \"maja\",\n    \"amount\": 50.0,\n    \"currency\": \"EUR\",\n    \"timestamp\": \"2026-05-08T16:00:00\",\n    \"type\": \"POS\",\n    \"country\": \"RS\",\n    \"city\": \"Beograd\",\n    \"mccCode\": \"supermarket\",\n    \"ipAddress\": null,\n    \"deviceFingerprint\": null\n  },\n  \"customerProfile\": {\n    \"customerId\": \"maja\",\n    \"age\": 30,\n    \"homeCountry\": \"RS\",\n    \"avgMonthlySpending\": 200.0,\n    \"bankRelationshipYears\": 4,\n    \"knownCountries\": [\"RS\"],\n    \"usualMccCodes\": [\"supermarket\"],\n    \"nightActivityFlag\": false\n  },\n  \"historicalTransactions\": [\n    {\n      \"id\": \"tx-daily-1\",\n      \"cardId\": \"card-maja\",\n      \"customerId\": \"maja\",\n      \"amount\": 60.0,\n      \"currency\": \"EUR\",\n      \"timestamp\": \"2026-05-08T09:00:00\",\n      \"type\": \"POS\",\n      \"country\": \"RS\",\n      \"city\": \"Beograd\",\n      \"mccCode\": \"supermarket\",\n      \"ipAddress\": null,\n      \"deviceFingerprint\": null\n    },\n    {\n      \"id\": \"tx-daily-2\",\n      \"cardId\": \"card-maja\",\n      \"customerId\": \"maja\",\n      \"amount\": 55.0,\n      \"currency\": \"EUR\",\n      \"timestamp\": \"2026-05-08T11:00:00\",\n      \"type\": \"POS\",\n      \"country\": \"RS\",\n      \"city\": \"Beograd\",\n      \"mccCode\": \"supermarket\",\n      \"ipAddress\": null,\n      \"deviceFingerprint\": null\n    },\n    {\n      \"id\": \"tx-daily-3\",\n      \"cardId\": \"card-maja\",\n      \"customerId\": \"maja\",\n      \"amount\": 45.0,\n      \"currency\": \"EUR\",\n      \"timestamp\": \"2026-05-08T13:00:00\",\n      \"type\": \"POS\",\n      \"country\": \"RS\",\n      \"city\": \"Beograd\",\n      \"mccCode\": \"supermarket\",\n      \"ipAddress\": null,\n      \"deviceFingerprint\": null\n    },\n    {\n      \"id\": \"tx-daily-4\",\n      \"cardId\": \"card-maja\",\n      \"customerId\": \"maja\",\n      \"amount\": 40.0,\n      \"currency\": \"EUR\",\n      \"timestamp\": \"2026-05-08T15:00:00\",\n      \"type\": \"POS\",\n      \"country\": \"RS\",\n      \"city\": \"Beograd\",\n      \"mccCode\": \"supermarket\",\n      \"ipAddress\": null,\n      \"deviceFingerprint\": null\n    }\n  ]\n}"
